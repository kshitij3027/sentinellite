# Verification variables (interpolated into stories.yaml before running /ui-review).
# Copy to verification/.env (gitignored). No real credentials needed — the
# dashboard has no login.

# Base URL of the Next.js dashboard.
DASHBOARD_URL=http://localhost:3000

# Tenant whose demo data to view. Populate it first with:
#   make replay                                  (writes to the "default" tenant)
#   sentinel attack replay teampcp --tenant <id> (any tenant)
TENANT=default
