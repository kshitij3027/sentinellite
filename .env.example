# SentinelLite configuration. Copy to .env to override defaults.
# The system runs end-to-end with NONE of these set (zero-cost promise).

# ---- LLM / agents ----
LLM_PROVIDER=ollama                     # ollama | openrouter | openai | anthropic
LLM_MODEL=qwen2.5:1.5b-instruct         # demo default (fast on CPU). Try qwen2.5:7b-instruct with more RAM/GPU.
OLLAMA_HOST=http://ollama:11434
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ---- triage thresholds (R4) ----
TRIAGE_AUTOCLOSE_CONF=0.90
TRIAGE_AUTOCLOSE_MAX_SEV=low            # low | medium | high | critical

# ---- investigation (R5/R6) ----
INVESTIGATION_PARALLELISM=3
INVESTIGATION_BUDGET_TOKENS=30000

# ---- actions / approval (R7/R8) ----
ACTION_DRY_RUN=true                     # set false ONLY with sandbox creds
APPROVAL_TIMEOUT_MIN=30

# ---- multi-tenancy & sovereignty (MT1/MT2) ----
TENANT_ID=default
AIRGAP_MODE=false                       # true disables ALL external network calls

# ---- source mode ----
ALERT_SOURCE_MODE=replay                # replay (public datasets) | live

# ---- datastores ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-please
POSTGRES_DSN=postgresql+asyncpg://sentinel:sentinel@postgres/sentinel
REDIS_URL=redis://redis:6379/0

# ---- observability (OB3) ----
LOG_LEVEL=INFO
LOG_JSON=true
ENABLE_LANGSMITH=false
# LANGSMITH_API_KEY=

# ---- Tier-1 threat intel (optional, free signup) ----
# VIRUSTOTAL_API_KEY=
# URLHAUS_AUTH_KEY=

# ---- bonus / live integrations (all opt-in) ----
# SLACK_WEBHOOK_URL=
AWS_LIVE_ENABLED=false
# GITHUB_PAT=
# OKTA_DOMAIN=
# OKTA_API_TOKEN=
FALCO_LIVE_ENABLED=false
